---
import AppLayout from '../../layouts/AppLayout.astro';
---
<AppLayout title="Browser RPA" active="browser">
  <div class="max-w-4xl space-y-5">
    <div>
      <h2 class="font-display font-bold text-white text-2xl mb-1">Browser RPA Agent</h2>
      <p class="text-muted text-sm">Describe the automation task. Qwen3.5 vision reads the page and generates a complete Playwright script.</p>
    </div>
    <div class="bg-wire border border-dim rounded-xl p-6 space-y-4">
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">Target URL</label>
        <input id="url" type="url" placeholder="https://example.com" class="field"/>
      </div>
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">Instruction</label>
        <textarea id="instr" rows="3" placeholder="Describe the automation task in plain English…" class="field resize-none"></textarea>
      </div>
      <div class="flex items-center justify-between">
        <label class="flex items-center gap-3 cursor-pointer">
          <input id="headless" type="checkbox" checked class="w-4 h-4 accent-accent"/>
          <span class="text-sm text-muted">Headless browser</span>
        </label>
        <button id="run-btn" class="btn-primary">▶ Run Automation</button>
      </div>
    </div>

    <!-- Examples -->
    <div class="bg-wire border border-dim rounded-xl p-5">
      <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Quick Examples</p>
      <div class="space-y-2">
        <button class="ex w-full text-left px-4 py-3 rounded-lg border border-dim hover:border-accent/30 hover:bg-dim/50 transition-all" data-url="https://example.com" data-instr="Extract the main heading and all paragraph text">
          <div class="text-xs text-accent font-mono mb-0.5">https://example.com</div>
          <div class="text-xs text-muted">Extract the main heading and all paragraph text</div>
        </button>
        <button class="ex w-full text-left px-4 py-3 rounded-lg border border-dim hover:border-accent/30 hover:bg-dim/50 transition-all" data-url="https://news.ycombinator.com" data-instr="Get the top 5 story titles and their points">
          <div class="text-xs text-accent font-mono mb-0.5">https://news.ycombinator.com</div>
          <div class="text-xs text-muted">Get the top 5 story titles and their points</div>
        </button>
        <button class="ex w-full text-left px-4 py-3 rounded-lg border border-dim hover:border-accent/30 hover:bg-dim/50 transition-all" data-url="https://quotes.toscrape.com" data-instr="Extract all quotes and authors on the page as JSON">
          <div class="text-xs text-accent font-mono mb-0.5">https://quotes.toscrape.com</div>
          <div class="text-xs text-muted">Extract all quotes and authors on the page as JSON</div>
        </button>
      </div>
    </div>

    <!-- Progress -->
    <div id="status-box" class="hidden bg-wire border border-accent/20 rounded-xl p-5 space-y-3">
      <div id="steps-row" class="flex items-center"></div>
      <p id="status-text" class="text-accent text-xs font-mono flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        <span id="status-msg">Starting…</span>
      </p>
    </div>
    <div id="error-box" class="hidden bg-accent2/10 border border-accent2/20 rounded-xl p-5">
      <p class="text-accent2 text-sm font-bold mb-1">Error</p>
      <p id="error-text" class="text-accent2/70 text-xs font-mono"></p>
    </div>
    <div id="result-box" class="hidden bg-wire border border-dim rounded-xl overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-dim">
        <span class="text-white text-sm font-bold flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green"></span>Result</span>
        <button id="copy-btn" class="text-xs text-muted hover:text-accent font-mono">Copy</button>
      </div>
      <div id="result-content" class="p-5 text-[13px] text-[#9ab0c8] font-mono leading-relaxed overflow-auto max-h-[500px]"></div>
    </div>
  </div>

  <script>
    let currentTaskId: string | null = null;
    let stuckTimer: ReturnType<typeof setTimeout> | null = null;
    function resetStuckTimer() {
      if (stuckTimer) clearTimeout(stuckTimer);
      stuckTimer = setTimeout(() => {
        if (!currentTaskId) return;
        const sb = document.getElementById('status-box')!;
        const eb = document.getElementById('error-box')!;
        const et = document.getElementById('error-text')!;
        sb.classList.add('hidden');
        eb.classList.remove('hidden');
        et.textContent = 'Timeout — server tidak merespons dalam 60 detik. Cek server logs.';
        const rb = document.getElementById('run-btn')!;
        rb.textContent = '▶ Run Automation'; rb.removeAttribute('disabled'); rb.classList.remove('opacity-60');
        currentTaskId = null;
      }, 60_000);
    }
    const runBtn    = document.getElementById('run-btn')!;
    const statusBox = document.getElementById('status-box')!;
    const stepsRow  = document.getElementById('steps-row')!;
    const statusMsg = document.getElementById('status-msg')!;
    const errorBox  = document.getElementById('error-box')!;
    const errorTxt  = document.getElementById('error-text')!;
    const resultBox = document.getElementById('result-box')!;
    const resultEl  = document.getElementById('result-content')!;
    const copyBtn   = document.getElementById('copy-btn')!;

    const STEPS = ['Sending', 'Chromium', 'Capturing', 'AI Analysis', 'Done'];
    function setStep(n: number, msg: string) {
      statusMsg.textContent = msg;
      let html = '';
      STEPS.forEach((s, i) => {
        const done = i < n, active = i === n, last = i === STEPS.length - 1;
        const dotCls = done ? 'bg-green border-green' : active ? 'bg-accent border-accent animate-pulse' : 'bg-transparent border-dim';
        const lblCls = done ? 'text-green' : active ? 'text-accent' : 'text-muted/40';
        html += `<div class="flex flex-col items-center min-w-fit"><div class="w-2.5 h-2.5 rounded-full border-2 ${dotCls} transition-colors"></div><span class="text-[9px] ${lblCls} mt-1 font-mono transition-colors">${done ? '✓' : s}</span></div>`;
        if (!last) { const lineCls = done ? 'step-line-done' : (active ? 'step-line-active' : 'step-line-dim'); html += `<div class="flex-1 ${lineCls} mx-1.5 -mt-3 transition-all"></div>`; }
      });
      stepsRow.innerHTML = html;
    }

    document.querySelectorAll('.ex').forEach(btn => {
      btn.addEventListener('click', () => {
        (document.getElementById('url') as HTMLInputElement).value = (btn as HTMLElement).dataset.url!;
        (document.getElementById('instr') as HTMLTextAreaElement).value = (btn as HTMLElement).dataset.instr!;
      });
    });

    copyBtn.onclick = () => navigator.clipboard.writeText(resultEl.innerText);

    function md(t: string) {
      return t.replace(/```[\s\S]*?```/g, m => `<pre class="bg-black/40 rounded p-3 my-2 overflow-x-auto">${m.replace(/```\w*\n?/g,'').trim()}</pre>`)
               .replace(/\*\*(.+?)\*\*/g,'<strong class="text-white">$1</strong>')
               .replace(/\n/g,'<br/>');
    }

    runBtn.onclick = async () => {
      const url   = (document.getElementById('url') as HTMLInputElement).value.trim();
      const instr = (document.getElementById('instr') as HTMLTextAreaElement).value.trim();
      const headless = (document.getElementById('headless') as HTMLInputElement).checked;
      if (!url || !instr) return;

      statusBox.classList.remove('hidden');
      errorBox.classList.add('hidden');
      resultBox.classList.add('hidden');
      runBtn.textContent = '⟳ Running…';
      runBtn.setAttribute('disabled','');
      runBtn.classList.add('opacity-60');
      setStep(0, 'Sending request to server…');

      try {
        const r = await fetch('/api/browser/run', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ url, instruction: instr, headless }),
        });
        const d = await r.json();
        if (d.error) throw new Error(d.error);
        currentTaskId = d.taskId;
        setStep(1, `Task ${currentTaskId} — launching Chromium…`);
        resetStuckTimer();
      } catch(e:any) {
        statusBox.classList.add('hidden');
        errorBox.classList.remove('hidden');
        errorTxt.textContent = e.message;
        runBtn.textContent = '▶ Run Automation';
        runBtn.removeAttribute('disabled');
        runBtn.classList.remove('opacity-60');
      }
    };

    (window as any).__aq_ws_listeners ??= new Set();
    (window as any).__aq_ws_listeners.add(async (msg: any) => {
      // Intermediate progress from server (Playwright stages)
      if (msg.type === 'browser_progress' && msg.taskId === currentTaskId) {
        resetStuckTimer();
        if (msg.step === 'chromium')   setStep(1, 'Launching Chromium…');
        if (msg.step === 'navigating') setStep(1, 'Navigating to page…');
        if (msg.step === 'capturing')  setStep(2, 'Capturing screenshot & page text…');
      }
      if (msg.type === 'browser_data_ready' && msg.taskId === currentTaskId) {
        if (stuckTimer) clearTimeout(stuckTimer);
        setStep(3, 'AI analyzing page via local Ollama…');
        resultBox.classList.remove('hidden');
        resultEl.innerHTML = '<span class="opacity-40 animate-pulse">▋</span>';
        try {
          let settings: any = {};
          try { settings = JSON.parse(localStorage.getItem('axonqwen-settings') || '{}'); } catch {}
          const ollamaUrl = settings.ollamaUrl || 'http://localhost:11434';
          const r = await fetch(`${ollamaUrl}/api/chat`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              model: settings.model || 'qwen3.5',
              stream: true,
              options: { temperature: 0.3, num_predict: 4096, num_ctx: settings.numCtx || 32768 },
              messages: [
                { role: 'system', content: 'You are AxonQwen Browser RPA Agent. You receive a screenshot and page text from a live browser.\nBased on the instruction, produce:\n1. **Automation Plan** — numbered steps\n2. **Playwright Script** — complete, runnable JavaScript with async/await\n3. **Expected Output** — what the script will return\n\nFormat in clean markdown with fenced code blocks.' },
                { role: 'user', content: `URL: ${msg.url}\nPage Title: ${msg.pageTitle}\n\nPage Content Preview:\n${msg.pageText}\n\n---\nInstruction: ${msg.instruction}`, images: msg.screenshot ? [msg.screenshot] : undefined },
              ],
            }),
          });
          if (!r.ok) throw new Error(`Ollama error: ${r.status}`);
          if (!r.body) throw new Error('No response body');

          const reader = r.body.getReader();
          const decoder = new TextDecoder();
          let buf = '', accumulated = '', thinkingText = '';
          while (true) {
            const {done,value} = await reader.read();
            if (done) break;
            buf += decoder.decode(value, {stream:true});
            const lines = buf.split('\n'); buf = lines.pop() ?? '';
            for (const line of lines) {
              if (!line.trim()) continue;
              try {
                const obj = JSON.parse(line);
                if (obj?.error) throw new Error(obj.error);
                const tok = obj?.message?.content || '';
                const think = obj?.message?.thinking || '';
                if (think) thinkingText += think;
                if (tok) accumulated += tok;
                if (think || tok) {
                  let html = '';
                  if (thinkingText) {
                    html += `<details class="mb-3" ${!accumulated ? 'open' : ''}>
                      <summary class="text-[11px] text-muted cursor-pointer select-none hover:text-accent"><span class="text-accent/60">◈</span> Thinking${!accumulated ? '<span class="animate-pulse ml-1">…</span>' : ''}</summary>
                      <div class="mt-1.5 pl-3 border-l border-dim text-xs text-muted/80">${md(thinkingText)}</div>
                    </details>`;
                  }
                  html += accumulated ? md(accumulated) : '';
                  resultEl.innerHTML = html || '<span class="opacity-40 animate-pulse">▋</span>';
                  resultEl.scrollTop = resultEl.scrollHeight;
                }
                if (obj?.done) break;
              } catch(pe:any) { if (pe.message && !pe.message.includes('JSON')) throw pe; }
            }
          }

          const output = accumulated || thinkingText || '';
          if (!output) resultEl.innerHTML = '<span class="text-muted italic">Model tidak memberikan respons.</span>';
          fetch(`/api/tasks/${currentTaskId}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: 'success', result: { output } }) }).catch(() => {});
          setStep(4, 'Complete!');
          setTimeout(() => statusBox.classList.add('hidden'), 1000);
        } catch (e: any) {
          statusBox.classList.add('hidden');
          errorBox.classList.remove('hidden');
          errorTxt.textContent = `AI error: ${e.message}. Pastikan Ollama berjalan di komputer Anda.`;
          resultBox.classList.add('hidden');
        }
        runBtn.textContent = '▶ Run Automation';
        runBtn.removeAttribute('disabled');
        runBtn.classList.remove('opacity-60');
      }
      if (msg.type === 'task_updated' && msg.task?.id === currentTaskId && msg.task?.status === 'failed') {
        if (stuckTimer) clearTimeout(stuckTimer);
        statusBox.classList.add('hidden');
        errorBox.classList.remove('hidden');
        errorTxt.textContent = msg.task.error ?? 'Task failed';
        runBtn.textContent = '▶ Run Automation';
        runBtn.removeAttribute('disabled');
        runBtn.classList.remove('opacity-60');
      }
    });
  </script>
</AppLayout>
