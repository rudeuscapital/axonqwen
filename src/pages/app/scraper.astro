---
import AppLayout from '../../layouts/AppLayout.astro';
---
<AppLayout title="Scraper Agent" active="scraper">
  <div class="max-w-3xl space-y-5">
    <div>
      <h2 class="font-display font-bold text-white text-2xl mb-1">Scraper Agent</h2>
      <p class="text-muted text-sm">Open any URL with real Chromium and extract structured JSON data with Qwen3.5.</p>
    </div>
    <div class="bg-wire border border-dim rounded-xl p-6 space-y-4">
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">URL to Scrape</label>
        <input id="url" type="url" placeholder="https://example.com" class="field"/>
      </div>
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">Fields (optional)</label>
        <input id="fields" type="text" placeholder="e.g. title, price, rating — or leave blank" class="field"/>
      </div>
      <button id="run-btn" class="btn-primary">◉ Run Scraper</button>
    </div>
    <div class="bg-wire border border-dim rounded-xl p-5">
      <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Examples</p>
      <div class="space-y-2" id="examples">
        <button class="ex w-full text-left px-4 py-3 rounded-lg border border-dim hover:border-accent/30 hover:bg-dim/50 transition-all" data-url="https://quotes.toscrape.com" data-fields="quote text, author, tags"><div class="text-xs text-accent font-mono">https://quotes.toscrape.com</div><div class="text-xs text-muted">Fields: quote text, author, tags</div></button>
        <button class="ex w-full text-left px-4 py-3 rounded-lg border border-dim hover:border-accent/30 hover:bg-dim/50 transition-all" data-url="https://books.toscrape.com" data-fields="title, price, rating, availability"><div class="text-xs text-accent font-mono">https://books.toscrape.com</div><div class="text-xs text-muted">Fields: title, price, rating, availability</div></button>
      </div>
    </div>
    <div id="status-box" class="hidden bg-wire border border-accent/20 rounded-xl p-5 space-y-3">
      <div id="steps-row" class="flex items-center"></div>
      <p class="text-accent text-xs font-mono flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        <span id="status-txt">Running…</span>
      </p>
    </div>
    <div id="error-box" class="hidden bg-accent2/10 border border-accent2/20 rounded-xl p-5"><p id="error-txt" class="text-accent2 text-sm font-mono"></p></div>
    <div id="result-box" class="hidden bg-wire border border-dim rounded-xl overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-dim">
        <span class="text-white text-sm font-bold flex gap-2 items-center"><span class="w-2 h-2 rounded-full bg-green"></span>Result</span>
        <button id="copy-btn" class="text-xs text-muted hover:text-accent font-mono">Copy JSON</button>
      </div>
      <pre id="result-content" class="p-5 text-[12px] text-[#9ab0c8] font-mono overflow-auto max-h-[480px] whitespace-pre-wrap"></pre>
    </div>
  </div>
  <script>
    let tid: string|null = null;
    document.querySelectorAll('.ex').forEach(b=>b.addEventListener('click',()=>{
      (document.getElementById('url') as HTMLInputElement).value=(b as HTMLElement).dataset.url!;
      (document.getElementById('fields') as HTMLInputElement).value=(b as HTMLElement).dataset.fields!;
    }));
    document.getElementById('copy-btn')!.onclick=()=>navigator.clipboard.writeText(document.getElementById('result-content')!.textContent??'');
    const runBtn=document.getElementById('run-btn')!;
    const stepsRow=document.getElementById('steps-row')!;
    const statusTxt=document.getElementById('status-txt')!;
    const STEPS=['Sending','Chromium','Scraping','AI Extract','Done'];
    function setStep(n:number,msg:string){
      statusTxt.textContent=msg;
      let h='';
      STEPS.forEach((s,i)=>{
        const done=i<n,active=i===n,last=i===STEPS.length-1;
        const dc=done?'bg-green border-green':active?'bg-accent border-accent animate-pulse':'bg-transparent border-dim';
        const lc=done?'text-green':active?'text-accent':'text-muted/40';
        h+=`<div class="flex flex-col items-center min-w-fit"><div class="w-2.5 h-2.5 rounded-full border-2 ${dc} transition-colors"></div><span class="text-[9px] ${lc} mt-1 font-mono transition-colors">${done?'✓':s}</span></div>`;
        if(!last){const lc=done?'step-line-done':active?'step-line-active':'step-line-dim';h+=`<div class="flex-1 ${lc} mx-1.5 -mt-3 transition-all"></div>`;}
      });
      stepsRow.innerHTML=h;
    }
    function scraperDone(){ runBtn.textContent='◉ Run Scraper'; runBtn.removeAttribute('disabled'); runBtn.classList.remove('opacity-60'); }
    runBtn.onclick=async()=>{
      const url=(document.getElementById('url') as HTMLInputElement).value.trim();
      const fields=(document.getElementById('fields') as HTMLInputElement).value.trim();
      if(!url)return;
      runBtn.textContent='⟳ Running…';
      runBtn.setAttribute('disabled','');
      runBtn.classList.add('opacity-60');
      document.getElementById('status-box')!.classList.remove('hidden');
      document.getElementById('error-box')!.classList.add('hidden');
      document.getElementById('result-box')!.classList.add('hidden');
      setStep(0,'Sending request to server…');
      const r=await fetch('/api/scraper/run',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({url,fields:fields||undefined})}).catch(e=>({json:()=>({error:e.message})}));
      const d=await r.json();
      if(d.error){document.getElementById('status-box')!.classList.add('hidden');document.getElementById('error-box')!.classList.remove('hidden');document.getElementById('error-txt')!.textContent=d.error;scraperDone();return;}
      tid=d.taskId;
      setStep(1,`Task ${tid} — launching Chromium…`);
    };
    (window as any).__aq_ws_listeners??=new Set();
    (window as any).__aq_ws_listeners.add(async (msg:any)=>{
      if(msg.type==='scraper_progress'&&msg.taskId===tid){
        if(msg.step==='chromium')  setStep(1,'Launching Chromium…');
        if(msg.step==='navigating')setStep(1,'Navigating to page…');
        if(msg.step==='scraping')  setStep(2,'Extracting page content…');
      }
      if(msg.type==='scraper_data_ready'&&msg.taskId===tid){
        setStep(3,'AI extracting data…');
        const resultBox=document.getElementById('result-box')!;
        const resultContent=document.getElementById('result-content')!;
        resultBox.classList.remove('hidden');
        resultContent.textContent='▋';
        try {
          let settings:any={};
          try{settings=JSON.parse(localStorage.getItem('axonqwen-settings')||'{}');}catch{}
          const ollamaUrl=settings.ollamaUrl||(location.origin+'/ollama');
          const r=await fetch(`${ollamaUrl}/api/chat`,{
            method:'POST',headers:{'Content-Type':'application/json'},
            body:JSON.stringify({
              model:settings.model||'qwen3.5',stream:true,
              options:{temperature:0.1,num_predict:8192,num_ctx:settings.numCtx||32768},
              messages:[
                {role:'system',content:'You are a data extraction specialist. Extract structured data from the web page content provided. Respond with ONLY valid JSON, no prose or markdown fences, in this exact shape:\n{"source":"url","title":"page title","fields":["f1","f2"],"count":0,"data":[...]}'},
                {role:'user',content:`URL: ${msg.url}\nPage Title: ${msg.pageTitle}\nFields to extract: ${msg.fields}\n\nPage Content:\n${msg.pageText}`},
              ],
            }),
          });
          if(!r.ok)throw new Error(`Ollama error: ${r.status}`);
          if(!r.body)throw new Error('No response body from AI service');

          const reader=r.body.getReader();
          const decoder=new TextDecoder();
          let buf='',accumulated='',thinkingText='';
          while(true){
            const{done,value}=await reader.read();
            if(done)break;
            buf+=decoder.decode(value,{stream:true});
            const lines=buf.split('\n');buf=lines.pop()??'';
            for(const line of lines){
              if(!line.trim())continue;
              try{
                const obj=JSON.parse(line);
                if(obj?.error)throw new Error(obj.error);
                const tok=obj?.message?.content||'';
                const think=obj?.message?.thinking||'';
                if(think)thinkingText+=think;
                if(tok)accumulated+=tok;
                if(tok) resultContent.textContent=accumulated;
                if(obj?.done)break;
              }catch(pe:any){if(pe.message&&!pe.message.includes('JSON'))throw pe;}
            }
          }
          const extracted=accumulated||thinkingText||'';
          if(!extracted) resultContent.textContent='Model did not respond.';
          else resultContent.textContent=extracted;
          fetch(`/api/tasks/${tid}`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'success',result:{extracted}})}).catch(()=>{});
          setStep(4,'Done!');
          setTimeout(()=>document.getElementById('status-box')!.classList.add('hidden'),1000);
          scraperDone();
        }catch(e:any){
          document.getElementById('status-box')!.classList.add('hidden');
          document.getElementById('error-box')!.classList.remove('hidden');
          document.getElementById('error-txt')!.textContent=`AI Error: ${e.message}. Please try again shortly.`;
          resultBox.classList.add('hidden');
          scraperDone();
        }
      }
      if(msg.type==='task_updated'&&msg.task?.id===tid&&msg.task?.status==='failed'){
        document.getElementById('status-box')!.classList.add('hidden');
        document.getElementById('error-box')!.classList.remove('hidden');
        document.getElementById('error-txt')!.textContent=msg.task.error??'Failed';
        scraperDone();
      }
    });
  </script>
</AppLayout>
