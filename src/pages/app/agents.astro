---
// src/pages/app/agents.astro — CSR
import AppLayout from '../../layouts/AppLayout.astro';

const agentDefs = [
  { id:'browser-rpa', name:'Browser RPA',    icon:'⬟', color:'accent',  href:'/app/browser', desc:'Otomasi browser berbasis Playwright dengan Qwen3.5 vision' },
  { id:'scraper',     name:'Scraper',         icon:'◉', color:'green',   href:'/app/scraper', desc:'Ekstraksi data terstruktur berbasis AI dari URL apapun' },
  { id:'vision',      name:'Vision',          icon:'◑', color:'gold',    href:'/app/vision',  desc:'Analisis gambar, OCR, dan ekstraksi data dokumen' },
  { id:'monitor',     name:'Monitor',         icon:'⊕', color:'accent2', href:'/app/monitor', desc:'Pemantauan URL terjadwal dengan kondisi bahasa alami' },
  { id:'chat',        name:'Chat (OpenClaw)', icon:'◈', color:'accent',  href:'/app/chat',    desc:'Percakapan streaming dengan memori persisten via OpenClaw' },
];

const BORDER: Record<string,string> = {
  accent: 'text-accent  border-accent/20  bg-accent/10',
  green:  'text-green   border-green/20   bg-green/10',
  gold:   'text-gold    border-gold/20    bg-gold/10',
  accent2:'text-accent2 border-accent2/20 bg-accent2/10',
};
---
<AppLayout title="Agen" active="agents">
  <div class="space-y-6">
    <div>
      <h2 class="font-display font-bold text-white text-2xl mb-1">Agen</h2>
      <p class="text-muted text-sm">Lima agen AI siap pakai, semuanya didukung model Qwen3.5 lokal Anda.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      {agentDefs.map(agent => {
        const c = BORDER[agent.color];
        return (
          <div class="bg-wire border border-dim rounded-xl p-6 hover:border-dim/80 transition-all relative overflow-hidden group">
            <div class="absolute inset-0 dark-grid-bg opacity-20 rounded-xl"></div>
            <div class="relative z-10">
              <div class="flex items-start justify-between mb-5">
                <div class={`w-10 h-10 rounded-xl flex items-center justify-center text-xl border ${c}`}>{agent.icon}</div>
                <div class="flex items-center gap-1.5 text-xs text-muted">
                  <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse-dot"></span>
                  Aktif
                </div>
              </div>
              <h3 class="font-display font-bold text-white text-lg mb-2">{agent.name}</h3>
              <p class="text-muted text-xs leading-relaxed mb-5">{agent.desc}</p>
              <div class="flex items-center justify-between text-xs mb-4 text-muted" id={`agent-stats-${agent.id}`}>
                <span>— tugas</span>
              </div>
              <a href={agent.href} class={`inline-flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-mono border transition-all ${c} hover:opacity-80`}>
                Buka Agen →
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
  <script>
    const AGENTS = ['browser-rpa','scraper','vision','monitor','chat'];
    fetch('/api/tasks').then(r => r.json()).then(({ tasks }) => {
      AGENTS.forEach(id => {
        const agentTasks = tasks.filter((t:any) => t.agent === id);
        const success = agentTasks.filter((t:any) => t.status === 'success').length;
        const rate = agentTasks.length > 0 ? Math.round(success / agentTasks.length * 100) : 0;
        const el = document.getElementById(`agent-stats-${id}`);
        if (el) {
          let html = `<span>${agentTasks.length} tugas · ${success} berhasil</span>`;
          if (agentTasks.length > 0) html += `<span class="text-green">${rate}% sukses</span>`;
          el.innerHTML = html;
        }
      });
    }).catch(() => {});
  </script>
</AppLayout>
