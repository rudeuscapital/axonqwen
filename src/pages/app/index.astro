---
// src/pages/app/index.astro — CSR Dashboard
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Dasbor" active="dashboard">
  <div class="space-y-6" id="dashboard">

    <!-- Stat cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="stat-card">
        <div class="absolute inset-0 dark-grid-bg opacity-20 rounded-xl"></div>
        <div class="relative z-10">
          <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Total Tugas</p>
          <p class="font-display font-extrabold text-4xl leading-none mb-1 text-accent" id="stat-total">—</p>
          <p class="text-xs text-muted mt-2" id="stat-running">memuat…</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="absolute inset-0 dark-grid-bg opacity-20 rounded-xl"></div>
        <div class="relative z-10">
          <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Tingkat Sukses</p>
          <p class="font-display font-extrabold text-4xl leading-none mb-1 text-green" id="stat-rate">—</p>
          <p class="text-xs text-muted mt-2" id="stat-passed">memuat…</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="absolute inset-0 dark-grid-bg opacity-20 rounded-xl"></div>
        <div class="relative z-10">
          <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Tugas Gagal</p>
          <p class="font-display font-extrabold text-4xl leading-none mb-1 text-accent2" id="stat-failed">—</p>
          <p class="text-xs text-muted mt-2">perlu perhatian</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="absolute inset-0 dark-grid-bg opacity-20 rounded-xl"></div>
        <div class="relative z-10">
          <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Status Ollama</p>
          <p class="font-display font-extrabold text-4xl leading-none mb-1 text-muted animate-pulse" id="stat-ollama">Memeriksa…</p>
          <p class="text-xs text-muted mt-2" id="stat-ollama-sub">lokal</p>
        </div>
      </div>
    </div>

    <!-- Tasks table + live log -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      <div class="lg:col-span-2 bg-wire border border-dim rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-dim">
          <h2 class="font-display font-bold text-sm text-white">Tugas Terbaru</h2>
          <a href="/app/tasks" class="text-xs text-muted hover:text-accent transition-colors">Lihat semua →</a>
        </div>
        <div id="task-list">
          <div class="px-5 py-8 text-center text-muted text-sm">Memuat tugas…</div>
        </div>
      </div>

      <div class="bg-wire border border-dim rounded-xl overflow-hidden">
        <div class="px-5 py-4 border-b border-dim flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-green animate-pulse-dot"></span>
          <h2 class="font-display font-bold text-sm text-white">Aktivitas Langsung</h2>
        </div>
        <div id="live-log" class="p-4 font-mono text-xs space-y-1.5 overflow-y-auto max-h-72">
          <p class="text-muted/40">Menunggu event…</p>
        </div>
      </div>
    </div>

    <!-- Quick actions -->
    <div class="bg-wire border border-dim rounded-xl p-6">
      <h2 class="font-display font-bold text-sm text-white mb-4">Aksi Cepat</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        <a href="/app/chat" class="flex items-center gap-2 px-4 py-3 rounded-lg bg-dim hover:bg-[#1a2038] border border-dim hover:border-accent/20 transition-all group"><span class="text-lg group-hover:text-accent transition-colors">◈</span><span class="text-[13px] text-muted group-hover:text-white">Agen Chat</span></a>
        <a href="/app/browser" class="flex items-center gap-2 px-4 py-3 rounded-lg bg-dim hover:bg-[#1a2038] border border-dim hover:border-accent/20 transition-all group"><span class="text-lg group-hover:text-accent transition-colors">⬟</span><span class="text-[13px] text-muted group-hover:text-white">Browser RPA</span></a>
        <a href="/app/scraper" class="flex items-center gap-2 px-4 py-3 rounded-lg bg-dim hover:bg-[#1a2038] border border-dim hover:border-accent/20 transition-all group"><span class="text-lg group-hover:text-accent transition-colors">◉</span><span class="text-[13px] text-muted group-hover:text-white">Scraper</span></a>
        <a href="/app/vision" class="flex items-center gap-2 px-4 py-3 rounded-lg bg-dim hover:bg-[#1a2038] border border-dim hover:border-accent/20 transition-all group"><span class="text-lg group-hover:text-accent transition-colors">◑</span><span class="text-[13px] text-muted group-hover:text-white">Vision</span></a>
        <a href="/app/monitor" class="flex items-center gap-2 px-4 py-3 rounded-lg bg-dim hover:bg-[#1a2038] border border-dim hover:border-accent/20 transition-all group"><span class="text-lg group-hover:text-accent transition-colors">⊕</span><span class="text-[13px] text-muted group-hover:text-white">Monitor</span></a>
      </div>
    </div>
  </div>

  <script>
    const logEl = document.getElementById('live-log')!;
    const STATUS_CLASS: Record<string,string> = {
      success:'badge badge-success', running:'badge badge-running',
      failed:'badge badge-failed', pending:'badge badge-pending',
      awaiting_ai:'badge badge-running',
    };

    function relTime(iso: string): string {
      const d = Date.now() - new Date(iso).getTime();
      if (d < 60_000)     return 'baru saja';
      if (d < 3_600_000)  return Math.floor(d / 60_000) + ' mnt lalu';
      if (d < 86_400_000) return Math.floor(d / 3_600_000) + ' jam lalu';
      return Math.floor(d / 86_400_000) + ' hari lalu';
    }

    function esc(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    async function loadDashboard() {
      try {
        const r = await fetch('/api/tasks');
        const { tasks } = await r.json();
        const recent = tasks.slice(0, 10);
        const total = tasks.length;
        const success = tasks.filter((t:any) => t.status === 'success').length;
        const failed = tasks.filter((t:any) => t.status === 'failed').length;
        const running = tasks.filter((t:any) => t.status === 'running').length;
        const rate = total > 0 ? Math.round((success / total) * 100) : 0;

        const el = (id: string) => document.getElementById(id);
        el('stat-total')!.textContent = String(total);
        el('stat-running')!.textContent = `${running} berjalan`;
        el('stat-rate')!.textContent = `${rate}%`;
        el('stat-passed')!.textContent = `${success} berhasil`;
        el('stat-failed')!.textContent = String(failed);

        const taskList = el('task-list')!;
        if (recent.length === 0) {
          taskList.innerHTML = '<div class="px-5 py-8 text-center text-muted text-sm">Belum ada tugas — jalankan agen untuk memulai.</div>';
        } else {
          taskList.innerHTML = recent.map((t:any) => `
            <div class="task-row">
              <span class="text-[11px] text-muted/60 font-mono w-16 flex-shrink-0">${esc(t.id)}</span>
              <span class="flex-1 text-white text-xs truncate">${esc(t.description)}</span>
              <span class="text-[10px] text-muted flex-shrink-0 hidden md:block">${relTime(t.startedAt)}</span>
              <span class="${STATUS_CLASS[t.status] || 'badge'} flex-shrink-0">${esc(t.status)}</span>
            </div>`).join('');
        }
      } catch {
        document.getElementById('task-list')!.innerHTML =
          '<div class="px-5 py-8 text-center text-muted text-sm">Tidak dapat terhubung ke server API.</div>';
      }
    }

    function addLog(msg: any) {
      const colors: Record<string,string> = {INFO:'text-[#9ab0c8]',OK:'text-green-400',WARN:'text-yellow-400',ERROR:'text-red-400'};
      const p = document.createElement('p');
      p.className = colors[msg.level] || 'text-muted';
      p.textContent = `[${msg.time}] [${msg.level}] ${msg.msg}`;
      if (logEl.firstChild?.textContent === 'Menunggu event…') logEl.innerHTML = '';
      logEl.prepend(p);
      if (logEl.children.length > 60) logEl.lastChild?.remove();
    }

    function onWS(msg: any) {
      if (msg.type === 'log') addLog(msg);
      if (['task_created','task_updated','task_result'].includes(msg.type)) {
        clearTimeout((window as any).__reloadTimer);
        (window as any).__reloadTimer = setTimeout(loadDashboard, 500);
      }
    }

    (window as any).__aq_ws_listeners ??= new Set();
    (window as any).__aq_ws_listeners.add(onWS);

    // Ollama status card
    (async function() {
      const valueEl = document.getElementById('stat-ollama')!;
      const subEl = document.getElementById('stat-ollama-sub')!;
      let settings: any = {};
      try { settings = JSON.parse(localStorage.getItem('axonqwen-settings') || '{}'); } catch {}
      const url = settings.ollamaUrl || 'http://localhost:11434';
      try {
        const r = await fetch(`${url}/api/tags`, { signal: AbortSignal.timeout(4000) });
        if (!r.ok) throw new Error();
        const data = await r.json();
        const model = data.models?.[0]?.name?.split(':')[0] || settings.model || 'qwen3.5';
        valueEl.textContent = 'Aktif'; valueEl.className = 'font-display font-extrabold text-4xl leading-none mb-1 text-green';
        subEl.textContent = model;
      } catch {
        valueEl.textContent = 'Mati'; valueEl.className = 'font-display font-extrabold text-4xl leading-none mb-1 text-accent2';
        subEl.textContent = 'tidak terhubung';
      }
    })();

    loadDashboard();
  </script>
</AppLayout>
