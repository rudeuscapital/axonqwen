---
import AppLayout from '../../layouts/AppLayout.astro';
---
<AppLayout title="Pengaturan" active="settings">
  <div class="max-w-2xl space-y-6">
    <div>
      <h2 class="font-display font-bold text-white text-2xl mb-1">Pengaturan</h2>
      <p class="text-muted text-sm">Konfigurasi koneksi Ollama, parameter model, dan default agen.</p>
    </div>
    <!-- Ollama Connection -->
    <div class="bg-wire border border-dim rounded-xl p-6 space-y-4">
      <div class="flex items-center justify-between">
        <h3 class="font-display font-bold text-white text-sm">Koneksi Ollama</h3>
        <span id="conn-status" class="text-xs flex items-center gap-2 text-muted">
          <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse-dot"></span>
          Memeriksa…
        </span>
      </div>
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">URL Ollama</label>
        <div class="flex gap-2">
          <input id="ollama-url" type="text" class="field flex-1 font-mono text-sm" placeholder="http://localhost:11434"/>
          <button id="test-conn-btn" class="btn-secondary text-xs px-4 whitespace-nowrap">Tes Koneksi</button>
        </div>
        <p class="text-[10px] text-muted/50 mt-1">URL Ollama yang berjalan di komputer Anda (default: http://localhost:11434)</p>
      </div>
      <div id="models-section" style="display:none">
        <p class="text-[10px] text-muted uppercase tracking-widest mb-2">Model Terinstall</p>
        <div id="models-list" class="flex flex-wrap gap-2"></div>
      </div>
    </div>
    <!-- Chat Preferences -->
    <div class="bg-wire border border-dim rounded-xl p-6 space-y-5">
      <h3 class="font-display font-bold text-white text-sm">Preferensi Chat</h3>
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">Model Default</label>
        <select id="pref-model" class="field">
          {['qwen3.5','qwen3.5:7b','qwen3.5:14b','qwen3.5:27b','qwen3.5:35b'].map(m=>(
            <option value={m}>{m}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">Temperatur Default: <span id="temp-val">0.6</span></label>
        <input id="pref-temp" type="range" min="0" max="2" step="0.1" value="0.6" class="w-full accent-accent" oninput="document.getElementById('temp-val').textContent=this.value"/>
      </div>
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">Jendela Konteks (num_ctx)</label>
        <select id="pref-ctx" class="field">
          {[8192,16384,32768,65536,131072,262144].map(n=>(
            <option value={n}>{(n/1024)+'K'}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">Maks Token (num_predict)</label>
        <select id="pref-maxtok" class="field">
          {[1024,2048,4096,8192,16384].map(n=>(
            <option value={n}>{n}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="text-[10px] text-muted uppercase tracking-widest block mb-2">Prompt Sistem Default</label>
        <textarea id="pref-sys" rows="4" class="field resize-none" placeholder="Prompt sistem opsional untuk Agen Chat…"></textarea>
      </div>
      <div class="flex gap-3">
        <button id="save-btn" class="btn-primary">Simpan Preferensi</button>
        <button id="reset-btn" class="btn-secondary text-xs">Reset ke Default</button>
      </div>
      <p id="save-msg" class="text-green-400 text-xs" style="display:none">Tersimpan!</p>
    </div>
  </div>
  <script>
    const STORAGE_KEY = 'axonqwen-settings';
    const DEFAULTS = {
      ollamaUrl:'http://localhost:11434', model:'qwen3.5', numCtx:32768,
      temperature:0.6, maxTokens:4096, systemPrompt:'',
    };

    function load(): any {
      try {
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored) return { ...DEFAULTS, ...JSON.parse(stored) };
        const legacy = localStorage.getItem('aq-prefs');
        if (legacy) {
          const p = JSON.parse(legacy);
          const migrated = { ...DEFAULTS, model: p.model ?? DEFAULTS.model, temperature: parseFloat(p.temperature) || DEFAULTS.temperature, systemPrompt: p.systemPrompt ?? '' };
          localStorage.setItem(STORAGE_KEY, JSON.stringify(migrated));
          localStorage.removeItem('aq-prefs');
          return migrated;
        }
      } catch {}
      return { ...DEFAULTS };
    }

    const prefs = load();
    const urlInput  = document.getElementById('ollama-url') as HTMLInputElement;
    const modelSel  = document.getElementById('pref-model') as HTMLSelectElement;
    const tempInput = document.getElementById('pref-temp') as HTMLInputElement;
    const ctxSel    = document.getElementById('pref-ctx') as HTMLSelectElement;
    const maxTokSel = document.getElementById('pref-maxtok') as HTMLSelectElement;
    const sysInput  = document.getElementById('pref-sys') as HTMLTextAreaElement;

    urlInput.value  = prefs.ollamaUrl;
    modelSel.value  = prefs.model;
    tempInput.value = String(prefs.temperature);
    document.getElementById('temp-val')!.textContent = String(prefs.temperature);
    ctxSel.value    = String(prefs.numCtx);
    maxTokSel.value = String(prefs.maxTokens);
    sysInput.value  = prefs.systemPrompt || '';

    // Test Ollama connection
    const testBtn = document.getElementById('test-conn-btn')!;
    async function testConnection() {
      const statusEl = document.getElementById('conn-status')!;
      const modelsSection = document.getElementById('models-section')!;
      const modelsList = document.getElementById('models-list')!;
      const url = urlInput.value.trim() || 'http://localhost:11434';

      testBtn.textContent = '⟳ Mengetes…';
      testBtn.setAttribute('disabled','');
      testBtn.classList.add('opacity-60');
      statusEl.className = 'text-xs flex items-center gap-2 text-muted';
      statusEl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse-dot"></span> Memeriksa…';

      try {
        const r = await fetch(`${url}/api/tags`, { signal: AbortSignal.timeout(4000) });
        if (!r.ok) throw new Error();
        const data = await r.json();
        const models: string[] = (data.models || []).map((m: any) => m.name);
        statusEl.className = 'text-xs flex items-center gap-2 text-green-400';
        statusEl.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse-dot"></span> Terhubung (${models.length} model)`;

        if (models.length > 0) {
          modelsSection.style.display = '';
          modelsList.innerHTML = models.map(m => `<span class="text-[11px] px-2 py-0.5 rounded border border-dim text-muted font-mono">${m}</span>`).join('');
        }
      } catch {
        statusEl.className = 'text-xs flex items-center gap-2 text-accent2';
        statusEl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse-dot"></span> Offline — pastikan Ollama berjalan';
        modelsSection.style.display = 'none';
      } finally {
        testBtn.textContent = 'Tes Koneksi';
        testBtn.removeAttribute('disabled');
        testBtn.classList.remove('opacity-60');
      }
    }

    testBtn.onclick = testConnection;
    testConnection();

    // Save
    const saveBtn = document.getElementById('save-btn')!;
    saveBtn.onclick = () => {
      saveBtn.textContent = '⟳ Menyimpan…';
      saveBtn.classList.add('opacity-60');
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        ollamaUrl:    urlInput.value.trim() || DEFAULTS.ollamaUrl,
        model:        modelSel.value,
        temperature:  parseFloat(tempInput.value) || DEFAULTS.temperature,
        numCtx:       parseInt(ctxSel.value) || DEFAULTS.numCtx,
        maxTokens:    parseInt(maxTokSel.value) || DEFAULTS.maxTokens,
        systemPrompt: sysInput.value,
      }));
      const msg = document.getElementById('save-msg')!;
      msg.style.display = '';
      saveBtn.textContent = '✓ Tersimpan!';
      setTimeout(() => { msg.style.display = 'none'; saveBtn.textContent = 'Simpan Preferensi'; saveBtn.classList.remove('opacity-60'); }, 1500);
    };

    // Reset
    document.getElementById('reset-btn')!.onclick = () => {
      localStorage.removeItem(STORAGE_KEY);
      localStorage.removeItem('aq-prefs');
      urlInput.value = DEFAULTS.ollamaUrl;
      modelSel.value = DEFAULTS.model;
      tempInput.value = String(DEFAULTS.temperature);
      document.getElementById('temp-val')!.textContent = String(DEFAULTS.temperature);
      ctxSel.value = String(DEFAULTS.numCtx);
      maxTokSel.value = String(DEFAULTS.maxTokens);
      sysInput.value = '';
      testConnection();
    };
  </script>
</AppLayout>
