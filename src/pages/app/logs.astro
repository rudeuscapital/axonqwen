---
import AppLayout from '../../layouts/AppLayout.astro';
---
<AppLayout title="Log" active="logs">
  <div class="space-y-4 h-full flex flex-col">
    <div class="flex items-center justify-between flex-shrink-0 flex-wrap gap-3">
      <div><h2 class="font-display font-bold text-white text-2xl mb-1">Log</h2><p class="text-muted text-sm">Stream log real-time via WebSocket.</p></div>
      <div class="flex items-center gap-2 flex-wrap">
        {['SEMUA','INFO','OK','WARN','ERROR'].map(f=>(
          <button class="filter-btn px-3 py-1.5 rounded text-xs font-mono transition-all border border-dim text-muted hover:text-white" data-filter={f}>{f}</button>
        ))}
        <button id="pause-btn" class="px-3 py-1.5 rounded text-xs font-mono border border-dim text-muted hover:text-white transition-all">⏸ Jeda</button>
        <button id="clear-btn" class="text-xs text-muted hover:text-accent2 font-mono px-2">✕ Hapus</button>
      </div>
    </div>
    <div id="log-terminal" class="flex-1 bg-[#02040a] border border-dim rounded-xl p-5 font-mono text-xs space-y-1 overflow-y-auto min-h-[400px]">
      <p class="text-muted/30">Menunggu log server… Pastikan server dev sedang berjalan.</p>
    </div>
  </div>
  <script>
    const terminal = document.getElementById('log-terminal')!;
    let activeFilter = 'SEMUA'; let paused = false;
    const logs: any[] = [];
    const colors: Record<string,string> = {INFO:'text-[#9ab0c8]',OK:'text-green-400',WARN:'text-yellow-400',ERROR:'text-red-400'};

    function render() {
      terminal.innerHTML = '';
      const filtered = activeFilter==='SEMUA' ? logs : logs.filter(l=>l.level===activeFilter);
      if(filtered.length===0){terminal.innerHTML='<p class="text-muted/30">Tidak ada log.</p>';return;}
      filtered.forEach(l=>{
        const p=document.createElement('p');
        p.className=`flex gap-3 ${colors[l.level]||'text-muted'}`;
        p.innerHTML=`<span class="text-muted/40 w-16 flex-shrink-0">${l.time}</span><span class="w-10 flex-shrink-0">[${l.level}]</span><span class="flex-1">${l.msg}</span>`;
        terminal.appendChild(p);
      });
      terminal.scrollTop=terminal.scrollHeight;
    }

    document.querySelectorAll('.filter-btn').forEach(b=>{
      b.addEventListener('click',()=>{
        activeFilter=(b as HTMLElement).dataset.filter!;
        document.querySelectorAll('.filter-btn').forEach(x=>x.classList.remove('bg-dim','text-accent','border-accent/30'));
        b.classList.add('bg-dim','text-accent','border-accent/30');
        render();
      });
    });
    document.getElementById('clear-btn')!.onclick=()=>{ logs.length=0; render(); };
    const pauseBtn = document.getElementById('pause-btn')!;
    pauseBtn.onclick=()=>{
      paused=!paused;
      pauseBtn.textContent=paused?'▶ Lanjut':'⏸ Jeda';
      pauseBtn.className=`px-3 py-1.5 rounded text-xs font-mono border transition-all ${paused?'border-yellow-400/30 text-yellow-400':'border-dim text-muted hover:text-white'}`;
    };

    (window as any).__aq_ws_listeners??=new Set();
    (window as any).__aq_ws_listeners.add((msg:any)=>{
      if(msg.type==='log'&&!paused){
        logs.push(msg); if(logs.length>500) logs.shift();
        render();
      }
    });
    // Activate SEMUA filter by default
    document.querySelector('[data-filter="SEMUA"]')?.classList.add('bg-dim','text-accent','border-accent/30');
  </script>
</AppLayout>
