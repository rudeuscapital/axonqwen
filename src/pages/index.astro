---
// src/pages/index.astro — Landing Page (Ollama status checked client-side)
import Base from '../layouts/Base.astro';

const ticker = ['Browser RPA','Vision & OCR','Smart Scraping','Auto Form Fill','Real-Time Monitoring','256K Context','Qwen3.5 Multimodal','OpenClaw Runtime','Playwright','Cloud Hosted','Enterprise Ready','Dedicated Infrastructure'];

const features = [
  { icon:'🌐', name:'Browser RPA',    tag:'Playwright · Vision',    desc:'Describe automation in natural language. Qwen3.5 vision reads the page and generates a complete Playwright script.' },
  { icon:'🔍', name:'Scraper Agent',   tag:'JSON · SPA · Pagination', desc:'Open any URL with real Chromium, extract structured JSON data from JS-rendered dynamic pages.' },
  { icon:'🖼️', name:'Vision Agent',    tag:'Multimodal · OCR',       desc:'Upload invoices, contracts, or any image. Qwen3.5 extracts all text, tables, and field values.' },
  { icon:'📡', name:'Monitor Agent',   tag:'Cron · Alerts',          desc:'Set up smart URL watchers with natural language conditions. Alerts sent via WebSocket instantly.' },
  { icon:'⚡', name:'Chat Agent',      tag:'SSE · Markdown',         desc:'Streaming chat with Qwen3.5. Full history, custom prompts, and markdown rendering.' },
  { icon:'📊', name:'Reporter',        tag:'Summarize · Format',     desc:'Compile and summarize scraped data into professional reports in JSON or markdown.' },
];

const steps = [
  {
    n:'01',
    t:'Connect Your Wallet',
    desc:'Visit axonqwen.xyz and connect your crypto wallet. We support MetaMask (EVM), Phantom (Solana), and Tonkeeper (TON).',
    code:'# Supported wallets\n🦊 MetaMask   — Ethereum, BSC, Polygon, Arbitrum, Base\n👻 Phantom    — Solana\n💎 Tonkeeper  — TON Network\n\n# Go to login\nhttps://axonqwen.xyz/login',
  },
  {
    n:'02',
    t:'Access the Dashboard',
    desc:'After wallet authentication, you\'re redirected to the dashboard with full access to all five AI agents.',
    code:'# Dashboard — overview of all agents & tasks\nhttps://axonqwen.xyz/app\n\n# Your wallet is shown in the sidebar\n# Disconnect anytime via the ✕ button',
  },
  {
    n:'03',
    t:'Start Automating',
    desc:'Choose an agent — Chat, Browser RPA, Scraper, Vision, or Monitor — and start your first task. Qwen3.5 is ready to go.',
    code:'# Available agents\n◈ Chat        — conversational AI assistant\n⬟ Browser RPA — Playwright-powered automation\n◉ Scraper     — structured data extraction\n◑ Vision      — image analysis & OCR\n⊕ Monitor     — scheduled URL monitoring',
  },
];
---
<Base title="Home">
  <!-- Custom cursor -->
  <div class="cursor fixed w-2.5 h-2.5 rounded-full bg-accent2 pointer-events-none z-[9999] mix-blend-multiply hidden md:block" id="c"></div>
  <div class="cursor-ring fixed w-8 h-8 rounded-full border border-ink pointer-events-none z-[9998] hidden md:block" id="cr"></div>

  <!-- NAV -->
  <nav class="fixed top-0 inset-x-0 z-50 bg-paper/90 backdrop-blur-xl border-b border-border">
    <div class="flex items-center justify-between px-4 sm:px-8 md:px-12 py-3 md:py-4">
      <a href="/" class="flex items-center gap-2 font-display font-extrabold text-base md:text-lg tracking-tight flex-shrink-0">
        <img src="/logo.png" alt="AxonQwen" class="w-7 h-7 md:w-8 md:h-8 object-contain"/>
        Axon<span class="text-accent">Qwen</span>
      </a>
      <div class="hidden lg:flex items-center gap-8">
        {[['features','#features'],['agents','#agents'],['usage','#usage'],['docs','#docs'],['roadmap','#roadmap']].map(([l,h])=>(
          <a href={h} class="text-xs text-muted uppercase tracking-widest hover:text-ink transition-colors">{l}</a>
        ))}
      </div>
      <div class="flex items-center gap-1.5 sm:gap-2">
        <!-- X (Twitter) -->
        <a href="https://x.com/AxonQwen" target="_blank" rel="noopener" class="hidden sm:flex items-center justify-center w-8 h-8 rounded-md border border-dim text-muted hover:text-ink hover:border-border transition-all" aria-label="Follow on X">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <!-- Token badge -->
        <span class="hidden md:flex text-[10px] px-3 py-1 rounded-full border font-mono items-center gap-2 border-accent/30 text-accent bg-accent/5">
          <span class="font-bold">$AXQWEN</span>
        </span>
        <!-- Buy button -->
        <a href="#" class="hidden md:inline-block text-[10px] px-3 py-1.5 rounded-md bg-green/10 text-green border border-green/30 hover:bg-green/20 transition-all font-mono font-bold">Buy $AXQWEN</a>
        <!-- Ollama badge (checked client-side) -->
        <span id="ollama-badge" class="text-[10px] px-3 py-1 rounded-full border font-mono items-center gap-2 border-dim text-muted bg-dim/5 hidden lg:flex">
          <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse-dot"></span>
          <span id="ollama-badge-text">Checking…</span>
        </span>
        <a href="/login" class="hidden sm:inline-block text-[10px] sm:text-xs px-3 sm:px-4 py-1.5 sm:py-2 rounded-md bg-ink text-paper hover:bg-accent hover:text-black transition-all font-mono font-bold whitespace-nowrap">Connect Wallet →</a>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden ml-1 p-2 text-muted hover:text-ink transition-colors" aria-label="Menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="3" y1="5" x2="17" y2="5"/><line x1="3" y1="10" x2="17" y2="10"/><line x1="3" y1="15" x2="17" y2="15"/>
          </svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu dropdown -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-border bg-paper/95 backdrop-blur-xl px-4 sm:px-8 py-4">
      <div class="flex flex-col gap-3">
        {[['Features','#features'],['Agents','#agents'],['Usage','#usage'],['Docs','#docs'],['Roadmap','#roadmap'],['$AXQWEN','#token']].map(([l,h])=>(
          <a href={h} class="text-xs text-muted uppercase tracking-widest hover:text-ink transition-colors py-1">{l}</a>
        ))}
        <div class="flex items-center gap-2 pt-2 border-t border-border">
          <a href="https://x.com/AxonQwen" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-[10px] px-3 py-1.5 rounded-md border border-dim text-muted hover:text-ink transition-all font-mono font-bold">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Follow
          </a>
          <a href="#" class="text-[10px] px-3 py-1.5 rounded-md bg-green/10 text-green border border-green/30 hover:bg-green/20 transition-all font-mono font-bold">Buy $AXQWEN</a>
          <a href="/login" class="text-[10px] px-3 py-1.5 rounded-md bg-ink text-paper hover:bg-accent hover:text-black transition-all font-mono font-bold">Connect Wallet →</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-end px-4 sm:px-8 md:px-12 pb-16 md:pb-20 pt-24 md:pt-28 relative overflow-hidden bg-paper">
    <div class="absolute inset-0 grid-bg opacity-50"></div>
    <div class="absolute inset-0 noise pointer-events-none"></div>

    <div class="absolute right-12 top-1/2 -translate-y-1/2 flex-col gap-px hidden xl:flex">
      {[['Static','Astro + Express'],['100%','Managed · Hosted'],['256K','Context Window'],['5','AI Agents']].map(([v,l])=>(
        <div class="bg-ink text-paper px-6 py-4 min-w-[168px] first:rounded-t-xl last:rounded-b-xl">
          <div class="font-display font-extrabold text-3xl text-accent leading-none mb-1">{v}</div>
          <div class="text-[10px] text-muted uppercase tracking-widest">{l}</div>
        </div>
      ))}
    </div>

    <div class="reveal">
      <div class="inline-flex items-center gap-2 bg-ink text-paper px-4 py-1.5 rounded-full text-[11px] font-mono uppercase tracking-widest mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse-dot"></span>
        Astro Static + React + Express API
      </div>
    </div>
    <h1 class="font-display font-extrabold leading-[.9] tracking-tight text-ink reveal delay-100 mb-8 max-w-3xl" style="font-size:clamp(56px,9vw,112px)">
      <span class="text-accent">AI Automation</span><br/>Platform<br/>
      <span style="-webkit-text-stroke:1.5px #040811;color:transparent">Enterprise.</span>
    </h1>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 reveal delay-200 max-w-4xl">
      <p class="text-muted text-sm leading-relaxed max-w-md font-mono">
        AxonQwen is a fully managed AI automation platform. Browser automation, visual analysis, smart scraping — powered by Qwen3.5 on dedicated infrastructure at axonqwen.xyz.
      </p>
      <div class="flex flex-wrap items-center gap-3 flex-shrink-0">
        <a href="/login" class="btn-primary">▶ Connect Wallet</a>
        <a href="#" class="btn-secondary">$AXQWEN →</a>
      </div>
    </div>
    <div class="absolute bottom-7 left-1/2 -translate-x-1/2 text-muted text-[10px] uppercase tracking-widest flex flex-col items-center gap-1 animate-bounce">
      <span>Scroll</span><span>↓</span>
    </div>
  </section>

  <!-- TICKER -->
  <div class="bg-ink border-y border-dim py-3.5 overflow-hidden">
    <div class="flex whitespace-nowrap animate-ticker">
      {[...ticker,...ticker].map(t=>(
        <span class="px-10 text-[11px] uppercase tracking-widest text-muted flex-shrink-0 flex items-center gap-4 after:content-['◈'] after:text-accent after:text-[8px]">{t}</span>
      ))}
    </div>
  </div>

  <!-- FEATURES -->
  <section class="bg-ink py-16 md:py-28 px-4 sm:px-8 md:px-12" id="features">
    <div class="max-w-6xl mx-auto">
      <p class="text-gold text-[10px] uppercase tracking-[.16em] mb-4 reveal">What AxonQwen Does</p>
      <h2 class="font-display font-extrabold text-white leading-tight tracking-tight mb-16 reveal delay-100" style="font-size:clamp(32px,4vw,52px)">All the Automation Tools You Need.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-dim rounded-xl overflow-hidden border border-dim reveal delay-200">
        {features.map(f=>(
          <div class="bg-wire p-9 hover:bg-[#1a2038] transition-colors cursor-default">
            <span class="text-3xl mb-5 block">{f.icon}</span>
            <h3 class="font-display font-bold text-white text-lg mb-3">{f.name}</h3>
            <p class="text-muted text-[13px] leading-relaxed mb-5">{f.desc}</p>
            <span class="text-[10px] px-3 py-1 rounded-full border border-dim text-muted/60">{f.tag}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AGENTS -->
  <section class="bg-paper py-16 md:py-28 px-4 sm:px-8 md:px-12" id="agents">
    <div class="max-w-5xl mx-auto">
      <p class="text-accent2 text-[10px] uppercase tracking-[.16em] mb-4 reveal">Built-in Agents</p>
      <h2 class="font-display font-extrabold text-ink leading-tight tracking-tight mb-16 reveal delay-100" style="font-size:clamp(32px,4vw,52px)">Five Agents, One Platform.</h2>
      <div class="border border-border rounded-xl overflow-hidden reveal">
        {[
          ['Browser RPA', 'Understands natural language and generates Playwright scripts. Combines vision and reasoning to navigate complex UIs.'],
          ['Scraper',     'Loads any URL with real Chromium (handles JS-rendered SPAs), then uses Qwen3.5 to parse into clean JSON.'],
          ['Vision',      'Send any image as base64. Qwen3.5 multimodal extracts all text, tables, and form fields — no external OCR needed.'],
          ['Monitor',     'Schedule periodic URL checks with natural language trigger conditions. Alerts sent via WebSocket instantly.'],
          ['Chat',        'Full streaming chat via API route → Ollama. Persistent memory through OpenClaw. Optional Telegram/Slack.'],
        ].map(([name, desc], i)=>(
          <div class="flex flex-col sm:flex-row items-start gap-3 sm:gap-8 px-4 sm:px-8 py-5 sm:py-7 border-b border-border last:border-0 hover:bg-paper2 transition-colors">
            <div class="font-display font-extrabold text-2xl sm:text-4xl text-border min-w-[40px] sm:min-w-[56px] leading-none">0{i+1}</div>
            <div class="flex-1">
              <h3 class="font-display font-bold text-ink text-lg sm:text-xl mb-2">{name} Agent</h3>
              <p class="text-muted text-[13px] leading-relaxed">{desc}</p>
            </div>
            <div class="flex items-center gap-1.5 text-xs text-muted flex-shrink-0 pt-1">
              <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse-dot"></span> Active
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW TO USE -->
  <section class="bg-ink py-16 md:py-28 px-4 sm:px-8 md:px-12" id="usage">
    <div class="max-w-5xl mx-auto">
      <p class="text-gold text-[10px] uppercase tracking-[.16em] mb-4 reveal">How to Use</p>
      <h2 class="font-display font-extrabold text-white leading-tight tracking-tight mb-6 reveal delay-100" style="font-size:clamp(32px,4vw,52px)">Complete Usage Guide.</h2>
      <p class="text-muted text-sm leading-relaxed max-w-lg mb-16 reveal delay-200">Learn how to use each agent to automate your workflows. Every agent is accessible from the dashboard at <code class="text-accent">axonqwen.xyz/app</code>.</p>

      <div class="space-y-6 reveal delay-300">
        <!-- Chat Agent -->
        <details class="group border border-dim rounded-xl overflow-hidden bg-wire">
          <summary class="flex items-center gap-4 px-8 py-6 cursor-pointer hover:bg-[#1a2038] transition-colors">
            <span class="text-2xl">&#x25C8;</span>
            <div class="flex-1">
              <h3 class="font-display font-bold text-white text-lg">Chat Agent</h3>
              <p class="text-muted text-xs mt-1">Conversational AI with streaming responses</p>
            </div>
            <span class="text-muted text-xs group-open:rotate-90 transition-transform">&#x25B6;</span>
          </summary>
          <div class="px-8 pb-8 border-t border-dim">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
              <div class="space-y-4">
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">1.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Open <code class="text-accent text-xs">Chat Agent</code> from the sidebar or go to <code class="text-accent text-xs">/app/chat</code></p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">2.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Type your message in the input box. Press <code class="text-accent text-xs">Enter</code> to send, <code class="text-accent text-xs">Shift+Enter</code> for new line</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">3.</span>
                  <p class="text-[13px] text-muted leading-relaxed">AI will stream the response in real-time with thinking process visible</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">4.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Adjust model, temperature, and system prompt from the Settings sidebar</p>
                </div>
              </div>
              <div class="bg-ink rounded-xl p-5">
                <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Quick Actions</p>
                <div class="space-y-2 text-xs font-mono text-[#9ab0c8]">
                  <p>&gt; List the steps to scrape a product page</p>
                  <p>&gt; Write a Playwright script to fill a login form</p>
                  <p>&gt; Extract all tables from a URL as JSON</p>
                  <p>&gt; Write automation to monitor price changes</p>
                </div>
              </div>
            </div>
          </div>
        </details>

        <!-- Browser RPA -->
        <details class="group border border-dim rounded-xl overflow-hidden bg-wire">
          <summary class="flex items-center gap-4 px-8 py-6 cursor-pointer hover:bg-[#1a2038] transition-colors">
            <span class="text-2xl">&#x2B1F;</span>
            <div class="flex-1">
              <h3 class="font-display font-bold text-white text-lg">Browser RPA</h3>
              <p class="text-muted text-xs mt-1">Automate any website with natural language</p>
            </div>
            <span class="text-muted text-xs group-open:rotate-90 transition-transform">&#x25B6;</span>
          </summary>
          <div class="px-8 pb-8 border-t border-dim">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
              <div class="space-y-4">
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">1.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Open <code class="text-accent text-xs">Browser RPA</code> from the sidebar</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">2.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Enter the target <strong class="text-white">URL</strong> (e.g. <code class="text-accent text-xs">https://example.com</code>)</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">3.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Describe the <strong class="text-white">instruction</strong> in natural language (e.g. "Click the login button and fill in email")</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">4.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Click <strong class="text-white">Run</strong> — Chromium will launch on the server, capture a screenshot, and AI will generate a Playwright script</p>
                </div>
              </div>
              <div class="bg-ink rounded-xl p-5">
                <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Process Flow</p>
                <div class="space-y-2 text-xs font-mono text-[#9ab0c8]">
                  <p class="text-accent">&#x2192; Chromium launches (headless)</p>
                  <p class="text-accent">&#x2192; Navigates to target URL</p>
                  <p class="text-accent">&#x2192; Takes screenshot + extracts page text</p>
                  <p class="text-accent">&#x2192; AI analyzes screenshot + instruction</p>
                  <p class="text-green-400">&#x2713; Generates Playwright automation script</p>
                </div>
              </div>
            </div>
          </div>
        </details>

        <!-- Scraper Agent -->
        <details class="group border border-dim rounded-xl overflow-hidden bg-wire">
          <summary class="flex items-center gap-4 px-8 py-6 cursor-pointer hover:bg-[#1a2038] transition-colors">
            <span class="text-2xl">&#x25C9;</span>
            <div class="flex-1">
              <h3 class="font-display font-bold text-white text-lg">Scraper Agent</h3>
              <p class="text-muted text-xs mt-1">Extract structured JSON from any website</p>
            </div>
            <span class="text-muted text-xs group-open:rotate-90 transition-transform">&#x25B6;</span>
          </summary>
          <div class="px-8 pb-8 border-t border-dim">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
              <div class="space-y-4">
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">1.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Open <code class="text-accent text-xs">Scraper</code> from the sidebar</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">2.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Enter the <strong class="text-white">URL</strong> to scrape</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">3.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Optionally specify <strong class="text-white">fields</strong> to extract (e.g. "title, price, rating") — leave blank for all data</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">4.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Click <strong class="text-white">Run Scraper</strong> — Chromium opens the page, AI extracts clean JSON</p>
                </div>
              </div>
              <div class="bg-ink rounded-xl p-5">
                <p class="text-[10px] text-muted uppercase tracking-widest mb-3">Example Output</p>
                <pre class="text-xs font-mono text-[#9ab0c8] leading-relaxed">{`{
  "source": "books.toscrape.com",
  "title": "Books to Scrape",
  "count": 20,
  "data": [
    { "title": "A Light in the Attic",
      "price": "51.77",
      "rating": "Three" }
  ]
}`}</pre>
              </div>
            </div>
          </div>
        </details>

        <!-- Vision Agent -->
        <details class="group border border-dim rounded-xl overflow-hidden bg-wire">
          <summary class="flex items-center gap-4 px-8 py-6 cursor-pointer hover:bg-[#1a2038] transition-colors">
            <span class="text-2xl">&#x25D1;</span>
            <div class="flex-1">
              <h3 class="font-display font-bold text-white text-lg">Vision Agent</h3>
              <p class="text-muted text-xs mt-1">Extract text and data from any image</p>
            </div>
            <span class="text-muted text-xs group-open:rotate-90 transition-transform">&#x25B6;</span>
          </summary>
          <div class="px-8 pb-8 border-t border-dim">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
              <div class="space-y-4">
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">1.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Open <code class="text-accent text-xs">Vision</code> from the sidebar</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">2.</span>
                  <p class="text-[13px] text-muted leading-relaxed"><strong class="text-white">Drag & drop</strong> an image or click to upload (JPEG, PNG, WebP)</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">3.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Optionally add <strong class="text-white">instructions</strong> (e.g. "Get all invoice items as JSON")</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-accent font-bold text-sm min-w-[24px]">4.</span>
                  <p class="text-[13px] text-muted leading-relaxed">Click <strong class="text-white">Analyze Image</strong> — AI extracts all text, tables, and structured data</p>
                </div>
              </div>
              <div class="bg-ink rounded-xl p-5">
