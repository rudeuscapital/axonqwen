---
// src/pages/index.astro — Landing Page (Ollama status checked client-side)
import Base from '../layouts/Base.astro';

const ticker = ['Browser RPA','Vision & OCR','Scraping Cerdas','Isi Form Otomatis','Monitoring Real-Time','256K Konteks','Qwen3.5 Multimodal','OpenClaw Runtime','Playwright','100% Lokal','Tanpa Cloud','Keamanan Enterprise'];

const features = [
  { icon:'🌐', name:'Browser RPA',    tag:'Playwright · Vision',    desc:'Deskripsikan otomasi dengan bahasa alami. Qwen3.5 vision membaca halaman dan menghasilkan script Playwright lengkap.' },
  { icon:'🔍', name:'Agen Scraper',   tag:'JSON · SPA · Paginasi',  desc:'Buka URL apapun dengan Chromium asli, ekstrak data JSON terstruktur dari halaman dinamis yang dirender JS.' },
  { icon:'🖼️', name:'Agen Vision',    tag:'Multimodal · OCR',       desc:'Unggah faktur, kontrak, atau gambar apapun. Qwen3.5 mengekstrak semua teks, tabel, dan nilai field.' },
  { icon:'📡', name:'Agen Monitor',   tag:'Cron · Peringatan',      desc:'Atur pemantau URL cerdas dengan kondisi bahasa alami. Peringatan dikirim via WebSocket secara instan.' },
  { icon:'⚡', name:'Agen Chat',      tag:'SSE · Markdown',         desc:'Chat streaming ke model Qwen3.5 lokal Anda. Riwayat penuh, prompt kustom, dan rendering markdown.' },
  { icon:'📊', name:'Reporter',       tag:'Rangkum · Format',       desc:'Kompilasi dan rangkum data yang di-scrape menjadi laporan profesional dalam JSON atau markdown.' },
];

const steps = [
  {
    n:'01',
    t:'Install Ollama',
    desc:'Download dan install Ollama dari ollama.com. Tersedia untuk Windows, macOS, dan Linux.',
    code:'# Windows (winget)\nwinget install Ollama.Ollama\n\n# macOS (Homebrew)\nbrew install ollama\n\n# Linux\ncurl -fsSL https://ollama.com/install.sh | sh',
  },
  {
    n:'02',
    t:'Jalankan Ollama & Pull Model',
    desc:'Setelah install, jalankan Ollama lalu download model Qwen 3.5. Pastikan Ollama tetap berjalan di background.',
    code:'# Jalankan Ollama server (biarkan terminal terbuka)\nollama serve\n\n# Buka terminal baru, download model\nollama pull qwen3.5\n\n# Verifikasi model terinstall\nollama list',
  },
  {
    n:'03',
    t:'Install Dependensi Proyek',
    desc:'Install npm packages dan browser Chromium untuk fitur Browser RPA dan Scraper.',
    code:'# Install dependensi\nnpm install\n\n# Install Chromium untuk Playwright\nnpx playwright install chromium',
  },
  {
    n:'04',
    t:'Jalankan AxonQwen',
    desc:'Mulai dev server. Dasbor akan tersedia di http://localhost:4321/app.',
    code:'# Jalankan dev server\nnpm run dev\n\n# Buka browser\n# → http://localhost:4321      (Halaman Utama)\n# → http://localhost:4321/app  (Dasbor)',
  },
];
---
<Base title="Beranda">
  <!-- Custom cursor -->
  <div class="cursor fixed w-2.5 h-2.5 rounded-full bg-accent2 pointer-events-none z-[9999] mix-blend-multiply" id="c"></div>
  <div class="cursor-ring fixed w-8 h-8 rounded-full border border-ink pointer-events-none z-[9998]" id="cr"></div>

  <!-- NAV -->
  <nav class="fixed top-0 inset-x-0 z-50 flex items-center justify-between px-12 py-4 bg-paper/90 backdrop-blur-xl border-b border-border">
    <a href="/" class="flex items-center gap-2.5 font-display font-extrabold text-lg tracking-tight">
      <img src="/logo.png" alt="AxonQwen" class="w-8 h-8 object-contain"/>
      Axon<span class="text-accent">Qwen</span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      {[['fitur','#features'],['agen','#agents'],['docs','#docs'],['mulai','#quickstart'],['model','#models']].map(([l,h])=>(
        <a href={h} class="text-xs text-muted uppercase tracking-widest hover:text-ink transition-colors">{l}</a>
      ))}
    </div>
    <div class="flex items-center gap-2">
      <!-- Ollama badge (checked client-side) -->
      <span id="ollama-badge" class="text-[10px] px-3 py-1 rounded-full border font-mono flex items-center gap-2 border-dim text-muted bg-dim/5">
        <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse-dot"></span>
        <span id="ollama-badge-text">Memeriksa…</span>
      </span>
      <a href="/app" class="text-xs px-4 py-2 rounded-md bg-ink text-paper hover:bg-accent hover:text-black transition-all font-mono font-bold">Buka App →</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-end px-12 pb-20 pt-28 relative overflow-hidden bg-paper">
    <div class="absolute inset-0 grid-bg opacity-50"></div>
    <div class="absolute inset-0 noise pointer-events-none"></div>

    <div class="absolute right-12 top-1/2 -translate-y-1/2 flex-col gap-px hidden xl:flex">
      {[['Static','Astro + Express'],['100%','Lokal · Tanpa Cloud'],['256K','Jendela Konteks'],['5','Agen AI']].map(([v,l])=>(
        <div class="bg-ink text-paper px-6 py-4 min-w-[168px] first:rounded-t-xl last:rounded-b-xl">
          <div class="font-display font-extrabold text-3xl text-accent leading-none mb-1">{v}</div>
          <div class="text-[10px] text-muted uppercase tracking-widest">{l}</div>
        </div>
      ))}
    </div>

    <div class="reveal">
      <div class="inline-flex items-center gap-2 bg-ink text-paper px-4 py-1.5 rounded-full text-[11px] font-mono uppercase tracking-widest mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse-dot"></span>
        Astro Static + React + Express API
      </div>
    </div>
    <h1 class="font-display font-extrabold leading-[.9] tracking-tight text-ink reveal delay-100 mb-8 max-w-3xl" style="font-size:clamp(56px,9vw,112px)">
      Platform<br/><span class="text-accent">Otomasi AI</span><br/>
      <span style="-webkit-text-stroke:1.5px #040811;color:transparent">Enterprise.</span>
    </h1>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 reveal delay-200 max-w-4xl">
      <p class="text-muted text-sm leading-relaxed max-w-md font-mono">
        AxonQwen berjalan sepenuhnya di perangkat Anda. Otomasi browser, analisis visual, scraping cerdas — didukung Qwen3.5, tanpa data yang keluar dari mesin Anda. Dibangun dengan Astro Static + Express.
      </p>
      <div class="flex items-center gap-3 flex-shrink-0">
        <a href="#quickstart" class="btn-primary">▶ Mulai Sekarang</a>
        <a href="/app" class="btn-secondary">Buka App →</a>
      </div>
    </div>
    <div class="absolute bottom-7 left-1/2 -translate-x-1/2 text-muted text-[10px] uppercase tracking-widest flex flex-col items-center gap-1 animate-bounce">
      <span>Gulir</span><span>↓</span>
    </div>
  </section>

  <!-- TICKER -->
  <div class="bg-ink border-y border-dim py-3.5 overflow-hidden">
    <div class="flex whitespace-nowrap animate-ticker">
      {[...ticker,...ticker].map(t=>(
        <span class="px-10 text-[11px] uppercase tracking-widest text-muted flex-shrink-0 flex items-center gap-4 after:content-['◈'] after:text-accent after:text-[8px]">{t}</span>
      ))}
    </div>
  </div>

  <!-- FEATURES -->
  <section class="bg-ink py-28 px-12" id="features">
    <div class="max-w-6xl mx-auto">
      <p class="text-gold text-[10px] uppercase tracking-[.16em] mb-4 reveal">Apa yang AxonQwen Lakukan</p>
      <h2 class="font-display font-extrabold text-white leading-tight tracking-tight mb-16 reveal delay-100" style="font-size:clamp(32px,4vw,52px)">Semua Alat Otomasi yang Anda Butuhkan.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-dim rounded-xl overflow-hidden border border-dim reveal delay-200">
        {features.map(f=>(
          <div class="bg-wire p-9 hover:bg-[#1a2038] transition-colors cursor-default">
            <span class="text-3xl mb-5 block">{f.icon}</span>
            <h3 class="font-display font-bold text-white text-lg mb-3">{f.name}</h3>
            <p class="text-muted text-[13px] leading-relaxed mb-5">{f.desc}</p>
            <span class="text-[10px] px-3 py-1 rounded-full border border-dim text-muted/60">{f.tag}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AGENTS -->
  <section class="bg-paper py-28 px-12" id="agents">
    <div class="max-w-5xl mx-auto">
      <p class="text-accent2 text-[10px] uppercase tracking-[.16em] mb-4 reveal">Agen Bawaan</p>
      <h2 class="font-display font-extrabold text-ink leading-tight tracking-tight mb-16 reveal delay-100" style="font-size:clamp(32px,4vw,52px)">Lima Agen, Satu Platform.</h2>
      <div class="border border-border rounded-xl overflow-hidden reveal">
        {[
          ['Browser RPA', 'Memahami bahasa alami dan menghasilkan script Playwright. Menggabungkan vision dan reasoning untuk menavigasi UI yang kompleks.'],
          ['Scraper',     'Memuat URL apapun dengan Chromium asli (menangani SPA yang dirender JS), lalu menggunakan Qwen3.5 untuk parsing menjadi JSON bersih.'],
          ['Vision',      'Kirim gambar apapun sebagai base64. Qwen3.5 multimodal mengekstrak semua teks, tabel, dan field formulir — tanpa OCR eksternal.'],
          ['Monitor',     'Jadwalkan pemeriksaan URL berkala dengan kondisi pemicu bahasa alami. Peringatan dikirim via WebSocket secara instan.'],
          ['Chat',        'Chat streaming penuh via API route → Ollama. Memori persisten melalui OpenClaw. Opsional Telegram/Slack.'],
        ].map(([name, desc], i)=>(
          <div class="flex items-start gap-8 px-8 py-7 border-b border-border last:border-0 hover:bg-paper2 transition-colors">
            <div class="font-display font-extrabold text-4xl text-border min-w-[56px] leading-none">0{i+1}</div>
            <div class="flex-1">
              <h3 class="font-display font-bold text-ink text-xl mb-2">Agen {name}</h3>
              <p class="text-muted text-[13px] leading-relaxed">{desc}</p>
            </div>
            <div class="flex items-center gap-1.5 text-xs text-muted flex-shrink-0 pt-1">
              <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse-dot"></span> Aktif
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DOCS -->
  <section class="bg-ink py-28 px-12" id="docs">
    <div class="max-w-5xl mx-auto">
      <p class="text-gold text-[10px] uppercase tracking-[.16em] mb-4 reveal">Referensi API</p>
      <h2 class="font-display font-extrabold text-white leading-tight tracking-tight mb-4 reveal delay-100" style="font-size:clamp(32px,4vw,52px)">Express API Routes.<br/>Server Mandiri.</h2>
      <p class="text-muted text-sm leading-relaxed max-w-lg mb-12 reveal delay-200">Semua endpoint adalah route handler Express — TypeScript murni, berjalan di server Node.js terpisah. Frontend disajikan sebagai file statis.</p>
      <div class="space-y-3 reveal delay-300">
        {[
          ['GET',   '/api/health',           'Kesehatan server + uptime',       'get'],
          ['GET',   '/api/ollama/status',    'Koneksi Ollama + daftar model',   'get'],
          ['POST',  '/api/chat',             'Chat completion streaming (SSE)',  'post'],
          ['GET',   '/api/tasks',            'Daftar semua tugas (terbaru)',     'get'],
          ['DELETE','/api/tasks/[id]',       'Hapus catatan tugas',             'del'],
          ['POST',  '/api/browser/run',      'Browser RPA — tugas Playwright',  'post'],
          ['POST',  '/api/scraper/run',      'Tugas web scraping',              'post'],
          ['POST',  '/api/vision/analyze',   'Analisis gambar (base64)',        'post'],
          ['POST',  '/api/monitor/start',    'Mulai monitor URL',               'post'],
          ['GET',   '/api/monitors',         'Daftar monitor aktif',            'get'],
          ['DELETE','/api/monitor/[id]',     'Hentikan monitor',                'del'],
        ].map(([m,p,d,cls])=>(
          <div class="flex items-center gap-3 px-4 py-3 bg-[#060912] border border-dim rounded-lg">
            <span class={`text-[10px] font-bold px-2 py-0.5 rounded border flex-shrink-0 ${
              cls==='get'  ? 'bg-green/10  text-green   border-green/20'  :
              cls==='post' ? 'bg-accent/10 text-accent  border-accent/20' :
                             'bg-accent2/10 text-accent2 border-accent2/20'
            }`}>{m}</span>
            <span class="text-sm text-[#9ab0c8] font-mono">{p}</span>
            <span class="ml-auto text-xs text-muted hidden md:block">{d}</span>
          </div>
        ))}
      </div>
      <div class="mt-10 reveal">
        <p class="text-[10px] text-muted uppercase tracking-widest mb-3">WebSocket — <code class="text-accent">ws://localhost:4321/_ws</code></p>
        <div class="code-block">
          <pre>{`const ws = new WebSocket('ws://localhost:4321/_ws');
ws.onmessage = ({ data }) => {
  const msg = JSON.parse(data);
  // msg.type: 'task_created' | 'task_updated' | 'task_result'
  //           'monitor_alert' | 'log' | 'connected'
};`}</pre>
        </div>
      </div>
    </div>
  </section>

  <!-- QUICKSTART -->
  <section class="bg-paper2 py-28 px-12" id="quickstart">
    <div class="max-w-4xl mx-auto">
      <p class="text-accent2 text-[10px] uppercase tracking-[.16em] mb-4 reveal">Memulai</p>
      <h2 class="font-display font-extrabold text-ink leading-tight tracking-tight mb-6 reveal delay-100" style="font-size:clamp(32px,4vw,52px)">Siap dalam 4 Langkah.</h2>
      <p class="text-muted text-sm leading-relaxed max-w-lg mb-16 reveal delay-200">
        AxonQwen membutuhkan Ollama sebagai AI engine lokal. Ikuti langkah berikut untuk memulai.
      </p>
      <div class="divide-y divide-border">
        {steps.map((s, i)=>(
          <div class={`flex gap-10 py-10 reveal delay-${(i+1)*100}`}>
            <div class="font-display font-extrabold text-4xl text-border min-w-[56px] leading-none">{s.n}</div>
            <div class="flex-1">
              <h3 class="font-display font-bold text-ink text-xl mb-2">{s.t}</h3>
              <p class="text-muted text-[13px] leading-relaxed mb-4">{s.desc}</p>
              <div class="bg-ink rounded-xl overflow-hidden">
                <pre class="px-6 py-5 text-[12px] leading-relaxed text-[#9ab0c8] overflow-x-auto font-mono whitespace-pre-wrap">{s.code}</pre>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Troubleshooting -->
      <div class="mt-16 bg-ink rounded-xl p-8 reveal" id="troubleshooting">
        <h3 class="font-display font-bold text-white text-lg mb-6 flex items-center gap-3">
          <span class="text-gold">!</span> Pemecahan Masalah
        </h3>
        <div class="space-y-5 text-sm font-mono">
          <div class="flex gap-4">
            <span class="text-accent2 flex-shrink-0 mt-0.5">T:</span>
            <div>
              <p class="text-white mb-2">Chat menampilkan error "fetch failed"</p>
              <p class="text-muted text-xs leading-relaxed">Ollama tidak berjalan. Buka terminal dan jalankan <code class="text-accent">ollama serve</code>. Pastikan URL di Pengaturan sesuai (default: <code class="text-accent">http://localhost:11434</code>).</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-accent2 flex-shrink-0 mt-0.5">T:</span>
            <div>
              <p class="text-white mb-2">Ollama berjalan tapi model tidak ditemukan</p>
              <p class="text-muted text-xs leading-relaxed">Pull model terlebih dahulu: <code class="text-accent">ollama pull qwen3.5</code>. Cek model tersedia dengan <code class="text-accent">ollama list</code>.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-accent2 flex-shrink-0 mt-0.5">T:</span>
            <div>
              <p class="text-white mb-2">Dasbor kosong / "Server offline"</p>
              <p class="text-muted text-xs leading-relaxed">Pastikan dev server berjalan (<code class="text-accent">npm run dev</code>) dan akses melalui <code class="text-accent">http://localhost:4321/app</code>.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <span class="text-accent2 flex-shrink-0 mt-0.5">T:</span>
            <div>
              <p class="text-white mb-2">Browser RPA / Scraper error</p>
              <p class="text-muted text-xs leading-relaxed">Install browser Chromium: <code class="text-accent">npx playwright install chromium</code>.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MODELS -->
  <section class="bg-paper py-28 px-12" id="models">
    <div class="max-w-5xl mx-auto">
      <p class="text-accent text-[10px] uppercase tracking-[.16em] mb-4 reveal">Pilihan Model</p>
      <h2 class="font-display font-extrabold text-ink leading-tight tracking-tight mb-12 reveal delay-100" style="font-size:clamp(32px,4vw,52px)">Pilih Model Qwen3.5 Anda.</h2>
      <div class="border border-border rounded-xl overflow-hidden reveal delay-200">
        <table class="w-full text-sm">
          <thead><tr class="bg-paper2 text-[10px] uppercase tracking-widest text-muted border-b border-border">
            <th class="px-6 py-3 text-left">Model</th>
            <th class="px-6 py-3 text-left font-mono">ID</th>
            <th class="px-6 py-3 text-left">RAM</th>
            <th class="px-6 py-3 text-left">Konteks</th>
            <th class="px-6 py-3"></th>
          </tr></thead>
          <tbody>
            {[
              ['Qwen 3.5 7B',  'qwen3.5:7b',  '8 GB',  '131K', false],
              ['Qwen 3.5',     'qwen3.5',      '10 GB', '256K', true ],
              ['Qwen 3.5 14B', 'qwen3.5:14b', '12 GB', '256K', false],
              ['Qwen 3.5 27B', 'qwen3.5:27b', '20 GB', '256K', false],
              ['Qwen 3.5 35B', 'qwen3.5:35b', '24 GB', '256K', false],
            ].map(([n,id,ram,ctx,rec])=>(
              <tr class="border-b border-border hover:bg-paper2 transition-colors last:border-0">
                <td class="px-6 py-4 font-display font-bold text-ink">{n}</td>
                <td class="px-6 py-4 font-mono text-muted text-xs">{id}</td>
                <td class="px-6 py-4 text-muted text-xs">{ram}</td>
                <td class="px-6 py-4 text-muted text-xs">{ctx}</td>
                <td class="px-6 py-4">{rec&&<span class="badge badge-success">Disarankan</span>}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-ink py-40 px-12 text-center relative overflow-hidden">
    <div class="absolute inset-0 dark-grid-bg opacity-30"></div>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-[600px] h-[400px] rounded-full bg-accent/5 blur-[80px]"></div>
    </div>
    <div class="relative z-10">
      <p class="text-gold text-[10px] uppercase tracking-[.16em] mb-6">Mulai Otomasi</p>
      <h2 class="font-display font-extrabold text-white leading-tight tracking-tight mb-6 reveal" style="font-size:clamp(40px,6vw,80px)">
        Tenaga Kerja AI Anda.<br/><span class="text-accent">Dimulai Sekarang.</span>
      </h2>
      <p class="text-muted text-sm mb-10 max-w-md mx-auto">Tanpa langganan. Tanpa biaya cloud. Tanpa data yang keluar dari mesin Anda.</p>
      <div class="flex items-center justify-center gap-4 reveal delay-200">
        <a href="#quickstart" class="btn-primary text-sm px-8 py-3">▶ Mulai Gratis</a>
        <a href="/app" class="btn-secondary text-sm px-8 py-3">Buka Dasbor →</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#020407] px-12 py-8 flex flex-col md:flex-row items-center justify-between gap-4 border-t border-dim">
    <div class="font-display font-extrabold text-white text-sm">Axon<span class="text-accent">Qwen</span></div>
    <div class="flex gap-6">
      {[['Fitur','#features'],['Agen','#agents'],['Docs','#docs'],['Mulai','#quickstart'],['Masalah','#troubleshooting'],['Dasbor','/app']].map(([l,h])=>(
        <a href={h} class="text-[11px] text-muted/50 hover:text-white transition-colors font-mono">{l}</a>
      ))}
    </div>
    <div class="text-[11px] text-muted/30 font-mono">Astro Static v1.0.0 · MIT · Qwen3.5 + Ollama</div>
  </footer>

  <script>
    // Custom cursor
    const c=document.getElementById('c')!,cr=document.getElementById('cr')!;
    let mx=0,my=0,rx=0,ry=0;
    document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;c.style.transform=`translate(${mx-5}px,${my-5}px)`;});
    (function ar(){rx+=(mx-rx-16)*.12;ry+=(my-ry-16)*.12;cr.style.transform=`translate(${rx}px,${ry}px)`;requestAnimationFrame(ar)})();

    // Reveal
    const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in');}),{threshold:.1});
    document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

    // Check user's local Ollama
    (async function() {
      const badge = document.getElementById('ollama-badge');
      const badgeText = document.getElementById('ollama-badge-text');
      let settings: any = {};
      try { settings = JSON.parse(localStorage.getItem('axonqwen-settings') || '{}'); } catch {}
      const url = settings.ollamaUrl || 'http://localhost:11434';
      try {
        const r = await fetch(`${url}/api/tags`, { signal: AbortSignal.timeout(4000) });
        if (!r.ok) throw new Error();
        const data = await r.json();
        const count = data.models?.length ?? 0;
        if (badge) badge.className = 'text-[10px] px-3 py-1 rounded-full border font-mono flex items-center gap-2 border-green/30 text-green bg-green/5';
        if (badgeText) badgeText.textContent = `Ollama: ${count} model`;
      } catch {
        if (badge) badge.className = 'text-[10px] px-3 py-1 rounded-full border font-mono flex items-center gap-2 border-accent2/30 text-accent2 bg-accent2/5';
        if (badgeText) badgeText.textContent = 'Ollama mati';
      }
    })();
  </script>
</Base>
